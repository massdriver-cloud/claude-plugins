# Resource Publishing Template
# Create one massdriver_artifact resource for each entry in massdriver.yaml's artifacts: section.
# (The HCL resource is still named `massdriver_artifact` in the provider; at runtime these
# become "resources" backed by their resource type — v2 terminology.)

resource "massdriver_artifact" "my_resource" {
  # field: Must exactly match the property name in massdriver.yaml artifacts section
  # If massdriver.yaml has artifacts.properties.database, use field = "database"
  field = "my_resource"

  # name: Display name shown in Massdriver UI
  name = "My Resource ${var.md_metadata.name_prefix}"

  # artifact: JSON payload must match the resource type's schema
  # If $ref: postgres, structure must match artifact-definitions/postgres.json
  artifact = jsonencode({
    # Required fields from the resource type
    id = "unique-identifier" # Usually from a resource attribute

    # Example: Database resource payload
    # auth = {
    #   hostname = aws_db_instance.main.endpoint
    #   port     = 5432
    #   database = var.database_name
    #   username = var.username
    #   password = random_password.main.result
    # }

    # Example: Network resource payload
    # cidr = var.cidr
    # subnets = [
    #   for s in aws_subnet.main : {
    #     id   = s.id
    #     cidr = s.cidr_block
    #     type = s.tags["type"]
    #   }
    # ]

    # Example: Policies array (common for IAM integration)
    # policies = [
    #   { id = "read-only", name = "Read Only" },
    #   { id = "read-write", name = "Read/Write" },
    #   { id = "admin", name = "Admin" }
    # ]
  })
}

# Multiple resources example:
# resource "massdriver_artifact" "database" {
#   field    = "database"
#   name     = "PostgreSQL ${var.md_metadata.name_prefix}"
#   artifact = jsonencode({ ... })
# }
#
# resource "massdriver_artifact" "cache" {
#   field    = "cache"
#   name     = "Redis ${var.md_metadata.name_prefix}"
#   artifact = jsonencode({ ... })
# }
